{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://diid.test/schemas/drivers-barriers.schema.json",
  "title": "Drivers and Barriers",
  "type": "object",
  "additionalProperties": false,
  "required": ["drivers", "barriers"],
  "properties": {
    "drivers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "body"],
        "properties": {
          "title": { "type": "string" },
          "body": { "type": "string" }
        }
      }
    },
    "barriers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "body"],
        "properties": {
          "title": { "type": "string" },
          "body": { "type": "string" }
        }
      }
    }
  }
}
