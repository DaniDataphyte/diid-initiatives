{
  "name": "diid-platform",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:all",
    "build:all": "npm run build:child-online-safety && npm run build:e-waste-nigeria",
    "dev:child-online-safety": "npm run dev --workspace @diid/child-online-safety",
    "dev:e-waste-nigeria": "npm run dev --workspace @diid/e-waste-nigeria",
    "build:child-online-safety": "npm run build --workspace @diid/child-online-safety",
    "build:e-waste-nigeria": "npm run build --workspace @diid/e-waste-nigeria",
    "preview:child-online-safety": "npm run preview --workspace @diid/child-online-safety",
    "preview:e-waste-nigeria": "npm run preview --workspace @diid/e-waste-nigeria"
  },
  "devDependencies": {
    "vite": "^8.0.0"
  },
  "dependencies": {
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/manrope": "^5.2.8",
    "alpinejs": "^3.15.12",
    "aos": "^2.3.4",
    "chart.js": "^4.5.1"
  }
}
